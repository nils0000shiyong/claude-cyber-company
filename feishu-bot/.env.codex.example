FEISHU_AGENT_ENGINE=codex
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
AGENT_TIMEOUT=300
AGENT_ALLOW_UNSAFE_PERMISSIONS=false
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never

# Access control
FEISHU_OWNER_OPEN_IDS=ou_your_owner_open_id
FEISHU_ALLOWED_OPEN_IDS=ou_member1,ou_member2
FEISHU_REJECT_MODE=silent

# Daily AI hotnews push (可选, 留空则不启用)
HOTNEWS_CHAT_ID=
HOTNEWS_HOUR=8
HOTNEWS_MINUTE=30
# 可选覆盖
# HOTNEWS_API_URL=https://aihot.virxact.com/api/public/daily
# HOTNEWS_MAX_ITEMS=10
# HOTNEWS_HTTP_TIMEOUT=20
